A;  }&#xA;  &#xA;  .deadline-label {&#xA;    font-size: 0.8em;&#xA;    opacity: 0.8;&#xA;    text-transform: uppercase;&#xA;    letter-spacing: 1px;&#xA;  }&#xA;  &#xA;  .deadline-date {&#xA;    font-size: 1em;&#xA;    margin: 4px 0;&#xA;  }&#xA;&#xA;  .journal-submission {&#xA;    font-size: 0.95em;&#xA;    margin: 8px 0;&#xA;    opacity: 0.95;&#xA;  }&#xA;  &#xA;  .days-left {&#xA;    font-size: 2em;&#xA;    font-weight: bold;&#xA;    margin: 12px 0;&#xA;  }&#xA;  &#xA;  .days-label {&#xA;    font-size: 0.9em;&#xA;    opacity: 0.9;&#xA;  }&#xA;  &#xA;  .conference-link {&#xA;    display: inline-block;&#xA;    margin-top: 12px;&#xA;    padding: 8px 16px;&#xA;    background: rgba(255,255,255,0.2);&#xA;    border-radius: 20px;&#xA;    color: white;&#xA;    text-decoration: none;&#xA;    font-size: 0.85em;&#xA;    transition: background 0.2s;&#xA;  }&#xA;  &#xA;  .conference-link:hover {&#xA;    background: rgba(255,255,255,0.3);&#xA;  }&#xA;  &#xA;  .loading {&#xA;    text-align: center;&#xA;    padding: 40px;&#xA;    color: #666;&#xA;  }&#xA;  &#xA;  .spinner {&#xA;    border: 4px solid #f3f3f3;&#xA;    border-top: 4px solid #667eea;&#xA;    border-radius: 50%;&#xA;    width: 40px;&#xA;    height: 40px;&#xA;    animation: spin 1s linear infinite;&#xA;    margin: 0 auto 20px;&#xA;  }&#xA;  &#xA;  @keyframes spin {&#xA;    0% { transform: rotate(0deg); }&#xA;    100% { transform: rotate(360deg); }&#xA;  }&#xA;  &#xA;  .error {&#xA;    background: #fff3f3;&#xA;    border: 1px solid #ffcdd2;&#xA;    color: #c62828;&#xA;    padding: 16px;&#xA;    border-radius: 8px;&#xA;    margin-bottom: 20px;&#xA;  }&#xA;  &#xA;  .last-updated {&#xA;    text-align: center;&#xA;    color: #888;&#xA;    font-size: 0.85em;&#xA;    margin-top: 20px;&#xA;  }&#xA;  &#xA;  .filter-buttons {&#xA;    display: flex;&#xA;    flex-wrap: wrap;&#xA;    gap: 8px;&#xA;    margin-bottom: 20px;&#xA;  }&#xA;  &#xA;  .filter-btn {&#xA;    padding: 8px 16px;&#xA;    border: 2px solid #e0e0e0;&#xA;    background: white;&#xA;    border-radius: 20px;&#xA;    cursor: pointer;&#xA;    font-size: 0.9em;&#xA;    transition: all 0.2s;&#xA;  }&#xA;  &#xA;  .filter-btn:hover {&#xA;    border-color: #667eea;&#xA;    color: #667eea;&#xA;  }&#xA;  &#xA;  .filter-btn.active {&#xA;    background: #667eea;&#xA;    border-color: #667eea;&#xA;    color: white;&#xA;  }&#xA;&#xA;  .tracker-tabs {&#xA;    max-width: 900px;&#xA;    margin: 0 auto 8px;&#xA;    padding: 0 20px;&#xA;    display: flex;&#xA;    flex-wrap: wrap;&#xA;    gap: 10px;&#xA;    box-sizing: border-box;&#xA;  }&#xA;&#xA;  .tracker-tab {&#xA;    flex: 1 1 180px;&#xA;    min-width: 0;&#xA;    padding: 9px 18px;&#xA;    border: 2px solid #e0e0e0;&#xA;    border-radius: 999px;&#xA;    background: white;&#xA;    cursor: pointer;&#xA;    font-size: 0.95em;&#xA;    text-align: center;&#xA;    transition: all 0.2s;&#xA;  }&#xA;&#xA;  .tracker-tab:hover {&#xA;    border-color: #667eea;&#xA;    color: #667eea;&#xA;  }&#xA;&#xA;  .tracker-tab.active {&#xA;    background: #667eea;&#xA;    border-color: #667eea;&#xA;    color: white;&#xA;  }&#xA;&#xA;  .tracker-panel.hidden {&#xA;    display: none;&#xA;  }&#xA;&#xA;  @media (max-width: 700px) {&#xA;    .tracker-tabs {&#xA;      padding: 0 12px;&#xA;      gap: 8px;&#xA;    }&#xA;&#xA;    .tracker-tab {&#xA;      flex: 1 1 calc(50% - 8px);&#xA;      padding: 8px 12px;&#xA;      font-size: 0.9em;&#xA;    }&#xA;  }&#xA;&#xA;  @media (max-width: 420px) {&#xA;    .tracker-tabs {&#xA;      padding: 0 10px;&#xA;    }&#xA;&#xA;    .tracker-tab {&#xA;      flex: 1 1 100%;&#xA;    }&#xA;  }&#xA;&lt;/style&gt;&#xA;&lt;div class=&#34;tracker-tabs&#34; role=&#34;tablist&#34; aria-label=&#34;Tracker views&#34;&gt;&#xA;  &lt;button class=&#34;tracker-tab active&#34; id=&#34;showConferences&#34; role=&#34;tab&#34; aria-selected=&#34;true&#34;&gt;Conferences&lt;/button&gt;&#xA;  &lt;button class=&#34;tracker-tab&#34; id=&#34;showWorkshops&#34; role=&#34;tab&#34; aria-selected=&#34;false&#34;&gt;Workshops&lt;/button&gt;&#xA;  &lt;button class=&#34;tracker-tab&#34; id=&#34;showJournals&#34; role=&#34;tab&#34; aria-selected=&#34;false&#34;&gt;Journals&lt;/button&gt;&#xA;&lt;/div&gt;&#xA;&lt;div class=&#34;conference-tracker tracker-panel&#34; id=&#34;conferencePanel&#34;&gt;&#xA;  &lt;input type=&#34;text&#34; class=&#34;search-box&#34; id=&#34;searchBox&#34; placeholder=&#34;Search conferences (e.g., PLDI, POPL, CGO...)&#34;&gt;&#xA;  &lt;div class=&#34;filter-buttons&#34;&gt;&#xA;    &lt;button class=&#34;filter-btn active&#34; data-filter=&#34;all&#34; data-type=&#34;conference&#34;&gt;All&lt;/button&gt;&#xA;    &lt;button class=&#34;filter-btn&#34; data-filter=&#34;urgent&#34; data-type=&#34;conference&#34;&gt;&lt; 7 days&lt;/button&gt;&#xA;    &lt;button class=&#34;filter-btn&#34; data-filter=&#34;soon&#34; data-type=&#34;conference&#34;&gt;&lt; 30 days&lt;/button&gt;&#xA;    &lt;button class=&#34;filter-btn&#34; data-filter=&#34;upcoming&#34; data-type=&#34;conference&#34;&gt;&lt; 90 days&lt;/button&gt;&#xA;    &lt;button class=&#34;filter-btn&#34; data-filter=&#34;active&#34; data-type=&#34;conference&#34;&gt;Active Only&lt;/button&gt;&#xA;  &lt;/div&gt;&#xA;  &lt;div id=&#34;conferenceList&#34; class=&#34;conference-grid&#34;&gt;&#xA;    &lt;div class=&#34;loading&#34;&gt;&#xA;      &lt;div class=&#34;spinner&#34;&gt;&lt;/div&gt;&#xA;      &lt;p&gt;Loading conference data...&lt;/p&gt;</description>
